# NEA Loss Analysis System — Environment Configuration
# Copy this file to the nea_work/ folder (same level as manage.py)

# ── Database ──────────────────────────────────────────────────
# To use PostgreSQL (recommended for production):
DB_ENGINE=django.db.backends.postgresql
DB_NAME=nea_loss_system
DB_USER=postgres
DB_PASSWORD=postgresql@79187
DB_HOST=localhost
DB_PORT=5432

# To temporarily fall back to SQLite (for local dev/testing):
# DB_ENGINE=django.db.backends.sqlite3

# ── Django ────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=nea-loss-system-secret-key-change-in-production-xyz123abc
ALLOWED_HOSTS=*,localhost,127.0.0.1